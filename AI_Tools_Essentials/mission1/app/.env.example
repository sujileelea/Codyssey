# =====================================================================
# 공고 분석 챗봇 환경설정
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.  cp .env.example .env
# LLM 호출은 OpenAI 호환 /v1/chat/completions 규격을 사용합니다.
# (Ollama 로컬 / OpenRouter / vLLM / LM Studio 모두 호환)
# =====================================================================

DEFAULT_MODEL_KEY=model1

# ---------------------------------------------------------------------
# 예시 A) Ollama 로 로컬 서빙하는 경우 (멀티모달 모델 필요)
#   ollama serve  후  ollama pull <model>
#   base_url 은 http://localhost:11434/v1, api_key 는 아무 값(ollama)
# ---------------------------------------------------------------------
MODEL1_LABEL=Gemma 4 E4B (31B)
MODEL1_BASE_URL=http://localhost:11434/v1
MODEL1_MODEL=gemma3:27b
MODEL1_API_KEY=ollama

MODEL2_LABEL=Llama 4 Scout
MODEL2_BASE_URL=http://localhost:11434/v1
MODEL2_MODEL=llama4:scout
MODEL2_API_KEY=ollama

MODEL3_LABEL=Qwen 3.6
MODEL3_BASE_URL=http://localhost:11434/v1
MODEL3_MODEL=qwen2.5vl:32b
MODEL3_API_KEY=ollama

# ---------------------------------------------------------------------
# 예시 B) OpenRouter 로 클라우드 서빙하는 경우
#   MODELn_BASE_URL=https://openrouter.ai/api/v1
#   MODELn_MODEL=<openrouter 모델 슬러그>  (예: google/gemma-3-27b-it 등)
#   MODELn_API_KEY=sk-or-...
# ---------------------------------------------------------------------

# 동작 파라미터
REQUEST_TIMEOUT=30
MAX_TEXT_CHARS=8000

# ─── RSS 피드 URL ────────────────────────────────────────
# 헤럴드 IT 카테고리 RSS (검증 완료, 23+ items). 다른 카테고리: /rss/google/{newsAll,economy,industry,...}
HERALD_RSS_URL=https://biz.heraldcorp.com/rss/google/it
BBC_RSS_URL=http://feeds.bbci.co.uk/news/technology/rss.xml

# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Notion ──────────────────────────────────────────────
NOTION_TOKEN=secret_...
# create_notion_db.mjs 실행 전: DB를 만들 상위 페이지 ID 입력
NOTION_PARENT_PAGE_ID=
# create_notion_db.mjs 실행 후: 출력된 DB ID 입력
NOTION_DATABASE_ID=

# ─── n8n (validate.mjs용) ────────────────────────────────
N8N_BASE_URL=http://localhost:5678
# n8n UI → Settings → API → Create API Key
N8N_API_KEY=
# workflow.json import 후 브라우저 URL에서 확인
N8N_WORKFLOW_ID=
